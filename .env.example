# ──────────────────────────────────────────────────────────
# Threads API 設定
# このファイルをコピーして .env を作成し、実際の値を入力してください。
# cp .env.example .env
#
# .env は絶対にGitにコミットしないこと（.gitignore に追加済みであること）
# ──────────────────────────────────────────────────────────

# Threads / Meta ユーザーアクセストークン
# 取得方法:
#   1. https://developers.facebook.com/ でアプリを作成
#   2. 「Threads API」プロダクトを追加
#   3. 必要なスコープを付与:
#      - threads_basic（プロフィール・投稿一覧）
#      - threads_manage_insights（インサイト取得 ※ビジネス/クリエイター限定）
#   4. Graph API Explorer または OAuth フローでトークンを取得
#   5. 長期トークン（60日有効）への交換を推奨:
#      GET https://graph.threads.net/access_token
#        ?grant_type=th_exchange_token
#        &client_id={app-id}
#        &client_secret={app-secret}
#        &access_token={short-lived-token}
THREADS_ACCESS_TOKEN=your_access_token_here

# Threads ユーザーID（数字）
# 取得方法:
#   トークン取得後、以下のエンドポイントにアクセス:
#   GET https://graph.threads.net/v1.0/me?fields=id&access_token={YOUR_TOKEN}
#   → レスポンスの "id" の値をコピーして貼り付ける
THREADS_USER_ID=your_numeric_user_id_here
